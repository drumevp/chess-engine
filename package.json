{
  "name": "@drumevp/chess-engine",
  "version": "1.0.0",
  "description": "A TypeScript bitboard chess move generation engine",
  "license": "MIT",
  "keywords": [
    "chess",
    "engine",
    "bitboard",
    "move-generation",
    "perft"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drumevp/chess-engine.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "drumevp-chess-engine": "./dist/drumevp-chess-engine.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "models/nnue/README.md",
    "models/nnue/defaultCheckpoint"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "asc --config asconfig.json --target release && tsx ./scripts/nnue/embedWasm.ts && tsup",
    "test-perft": "tsx ./scripts/perft.ts --max-depth 4",
    "test-perft:deep": "tsx ./scripts/perft.ts --max-depth 5",
    "export-precalculated-data": "tsx ./scripts/precalculateAttackTables.ts",
    "nnue:train": "tsx ./scripts/nnue/train.ts",
    "engine:elo": "tsx ./scripts/engine/estimateElo.ts",
    "pack:dry": "npm pack --dry-run"
  },
  "devDependencies": {
    "@tensorflow/tfjs-node": "^4.22.0",
    "@types/node": "^25.9.1",
    "assemblyscript": "^0.28.19",
    "tsup": "^8.0.0",
    "tsx": "^4.22.3",
    "typescript": "~6.0.2"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "tar": "7.5.16"
  }
}
