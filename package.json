{
  "name": "@drumevp/chess-engine",
  "version": "0.2.0",
  "description": "A TypeScript bitboard chess move generation engine",
  "license": "MIT",
  "keywords": ["chess", "engine", "bitboard", "move-generation", "perft"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drumevp/chess-engine.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test-perft": "tsx ./scripts/perft.ts --max-depth 4",
    "test-perft:deep": "tsx ./scripts/perft.ts --max-depth 5",
    "export-precalculated-data": "tsx ./scripts/precalculateAttackTables.ts",
    "nnue:prepare-stockfish": "tsx ./scripts/nnue/prepareStockfish.ts",
    "nnue:export-default": "tsx ./scripts/nnue/exportDefaultModel.ts",
    "nnue:generate-training-data": "tsx ./scripts/nnue/generateTrainingData.ts",
    "nnue:train": "tsx ./scripts/nnue/trainNnue.ts",
    "nnue:estimate-elo": "tsx ./scripts/nnue/estimateNnueElo.ts",
    "nnue:play-stockfish": "tsx ./scripts/nnue/playStockfishMatch.ts",
    "nnue:verify-accumulator": "tsx ./scripts/nnue/verifyAccumulator.ts",
    "nnue:verify-full-threats": "tsx ./scripts/nnue/verifyFullThreats.ts",
    "pack:dry": "npm pack --dry-run"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.0.0",
    "tsx": "^4.22.3",
    "typescript": "~6.0.2"
  }
}
